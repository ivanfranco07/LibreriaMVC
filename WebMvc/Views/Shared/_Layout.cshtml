@using Microsoft.AspNetCore.Identity
@inject SignInManager<Usuario> SignInManager
@inject UserManager<Usuario> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebMvc</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebMvc.styles.css" asp-append-version="true" />
    @* DataTableCSS *@
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.8/css/dataTables.dataTables.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom fixed-top px-4">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary" href="/">DotNet Books</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            @if (UserManager.IsInRoleAsync(await UserManager.GetUserAsync(User), "Admin").Result)
                            {
                                <li class="nav-item"><a asp-controller="Libro" asp-action="Index" class="nav-link active">Libros</a></li>
                            }
                        }
                    </ul>
                    <form class="d-flex me-3">
                        <input class="form-control me-2" type="search" placeholder="Buscar artículo" aria-label="Search">
                    </form>
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <div class="d-flex align-items-center">
                            <a asp-controller="Usuario" asp-action="Mi perfil" class="btn btn-link text-dark text-decoration-none me-3">Mi perfil</a>
                            <a asp-controller="Usuario" asp-action="SignOut" class="btn btn-danger">Cerrar sesión</a>
                        </div>
                    }
                    else
                    {

                    <div class="d-flex align-items-center">
                        <a asp-controller="Usuario" asp-action="LogIn" class="btn btn-link text-dark text-decoration-none me-3">Iniciar sesión</a>
                        <a asp-controller="Usuario" asp-action="SignUp" class="btn btn-primary">Registrarse</a>
                    </div>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - WebMvc - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @* DataTableJS *@
    <script src="https://cdn.datatables.net/2.3.8/js/dataTables.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
