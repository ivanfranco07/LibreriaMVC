@model ProfileViewModel
@{
    ViewData["Title"] = "Perfil de Usuario";
}
}
<div class="container mt-5 pt-5 pb-5">
    <!-- Profile Header Card -->
    <div class="card border-0 shadow-sm p-4 mb-4 mt-4">
        <div class="d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-4">
                <div class="position-relative">
                    <img src="https://ui-avatars.com/api/?name=Anders+Helisberg&background=0078d4&color=fff&size=128" class="rounded-3 shadow-sm" alt="Profile">
                    <button class="btn btn-primary btn-sm rounded-circle position-absolute bottom-0 end-0 m-1" style="width: 32px; height: 32px; padding: 0;">
                        <i class="bi bi-pencil-fill" style="font-size: 12px;"></i>
                    </button>
                </div>
                <div>
                    <h1 class="fw-bold mb-0">@Model.Nombre</h1>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Form Content -->
        <div class="col-lg">
            <div class="card border-0 shadow-sm p-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="fw-bold h4 mb-0">Información personal</h2>
                    <button type="submit" class="btn btn-link text-primary text-decoration-none fw-bold p-0">
                        <i class="bi bi-save me-1"></i> Guardar cambios
                    </button>
                </div>

                <form>
                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-secondary">Nombre</label>
                            <input type="text" class="form-control bg-light border-0 py-2" value="@Model.Nombre">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-secondary">Apellido</label>
                            <input type="text" class="form-control bg-light border-0 py-2" value="@Model.Apellido">
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-secondary">Correo electrónico</label>
                            <input type="email" class="form-control bg-light border-0 py-2" value="@Model.Email">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-secondary">Fecha de nacimiento</label>
                            <input type="text" class="form-control bg-light border-0 py-2" value="@Model.FechaNacimiento">
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>